# OIDC Identity Provider Configuration
# Set these from your OIDC server (e.g., Konoha OIDC Service)
OIDC_ISSUER=https://konoha-oidc-service.onrender.com
OIDC_CLIENT_ID=your_client_id_here
OIDC_CLIENT_SECRET=your_client_secret_here

# App URL Configuration
# For local dev use http://localhost:8000
# For production use your deployed URL (e.g., https://my-kafka-app.onrender.com)
APP_URL=http://localhost:8000

# Security
# Random secure string for signing JWT session cookies
SESSION_SECRET=your_secure_random_string_here

# Server Port
PORT=8000
